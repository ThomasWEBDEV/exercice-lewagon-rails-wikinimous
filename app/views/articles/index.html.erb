<h1 class="mb-4"> 📚All Articles</h1>

<%= link_to new_article_path, class: "btn btn-success mb-3" do %>
  <i class="fas fa-plus"></i> New Article
<% end %>

<ul class="list-group">
  <% @articles.each do |article| %>
    <li class="list-group-item d-flex justify-content-between align-items-center">
      <div>
        <%= link_to article.title, article_path(article), class: "fw-bold text-decoration-none" %><br>
        <small class="text-muted"><%= truncate(article.content, length: 100) %></small>
      </div>
      <div>
        <%= link_to edit_article_path(article), class: "btn btn-sm btn-outline-primary me-2" do %>
          <i class="fas fa-pen"></i>
        <% end %>

        <%= link_to article_path(article), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" do %>
          <i class="fas fa-trash"></i>
        <% end %>
      </div>
    </li>
  <% end %>
</ul>
